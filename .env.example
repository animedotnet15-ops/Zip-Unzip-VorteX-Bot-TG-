# Get this from @BotFather on Telegram
BOT_TOKEN=123456789:AAExampleTokenReplaceMe

# Your bot's @username, WITHOUT the @
BOT_USERNAME=zip_unzip_7z_bot

# Your personal numeric Telegram user ID (get it from @userinfobot).
# The owner is a permanent super-admin and can add/remove other admins.
OWNER_ID=8337976117

# Where the SQLite database file will be stored
DATABASE_PATH=zipbot.db

# Local scratch folder used while zipping/unzipping (auto-created)
WORK_DIR=zip_workdir

# OPTIONAL: base URL of a self-hosted Telegram Bot API server
# (https://github.com/tdlib/telegram-bot-api) — needed to handle files
# bigger than ~20MB. Leave blank to use the official cloud Bot API.
LOCAL_BOT_API_BASE=

# Soft cap you want to advertise to users (informational only)
MAX_UPLOAD_MB=2000
